generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma" // Required in v7
}

// organisationId
datasource db {
  provider = "postgresql"
  // Note: No 'url' here anymore
}

//
// ─────────────────────────────────────────────
// 1. ORGANISATION (MULTI-TENANT ROOT)
// ─────────────────────────────────────────────
//

model Organisation {
  id   String @id @default(cuid())
  name String
  slug String @unique

  logoUrl      String?
  contactEmail String?
  contactPhone String?
  address      String?

  createdAt DateTime @default(now())

  // ─────────────────────────────────────────────
  // Core Relations (strict multi-tenant boundary)
  // ─────────────────────────────────────────────
  users          User[]
  staff          Staff[]
  clients        Client[]
  jobs           Job[]
  prices         PriceList[]
  stockItems     StockItem[]
  stockMovements StockMovement[]
  deliveries     Delivery[]
  b2bPushes      B2BPush[]
  auditLogs      AuditLog[]
  outboxEvents   OutboxEvent[]
  payments       Payment[]

  // ─────────────────────────────────────────────
  // Performance + SaaS scaling indexes
  // ─────────────────────────────────────────────
  @@index([name])
  @@index([slug])
  @@index([createdAt])
}

//
// ─────────────────────────────────────────────
// 2. AUTH / USERS / RBAC
// ─────────────────────────────────────────────
//

model OutboxEvent {
  id      String @id @default(cuid())
  type    String
  payload Json
  orgId   String

  // Add this to link it properly
  organisation Organisation @relation(fields: [orgId], references: [id])

  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  // Add this index for performance
  @@index([orgId])
  @@index([status])
}

enum UserRole {
  ADMIN
  OPERATOR
  CASHIER
  GUEST
  GRAPHIC_DESIGNER
}

model User {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  email     String
  role      UserRole
  avatarUrl String?
  createdAt DateTime @default(now())

  organisation Organisation @relation(fields: [orgId], references: [id])
  staffProfile Staff?

  @@unique([orgId, email])
  @@index([orgId])
}

//
// ─────────────────────────────────────────────
// 3. STAFF
// ─────────────────────────────────────────────
//

model Staff {
  id    String @id @default(cuid())
  orgId String

  // Relation to identity
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Professional-only fields
  phone          String?
  specialisation String?
  isActive       Boolean @default(true)

  organisation Organisation @relation(fields: [orgId], references: [id])
  assignedJobs Job[]        @relation("StaffJobs")

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([orgId, isActive])
}

//
// ─────────────────────────────────────────────
// 4. CLIENTS
// ─────────────────────────────────────────────
//

enum ClientType {
  PRIVATE
  COMPANY
}

model Client {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  type        ClientType
  name        String
  companyName String?
  email       String?
  phone       String
  location    String?

  profilePictureUrl String?

  // ─────────────────────────────────────────────
  // Lightweight CRM state (cached projections)
  // ─────────────────────────────────────────────
  isNew         Boolean @default(true)
  recentStaffId String?

  lastJobId   String?
  lastJobDate DateTime?

  totalJobs Int @default(0)

  mostPrintedServiceId String?

  notes String?

  // ─────────────────────────────────────────────
  // Relations
  // ─────────────────────────────────────────────
  jobs Job[]

  createdAt  DateTime   @default(now())
  deliveries Delivery[]

  // ─────────────────────────────────────────────
  // INDEXING (SaaS + CRM performance layer)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, phone])
  @@index([orgId, name])
  @@index([orgId, lastJobDate])
  @@index([orgId, totalJobs])
  @@index([orgId, isNew])
  @@index([recentStaffId])
  @@index([mostPrintedServiceId])
  @@index([lastJobId])
}

//
// ─────────────────────────────────────────────
// 5. PRICE LIST
// ─────────────────────────────────────────────
//

enum PriceItemType {
  MATERIAL
  SERVICE
}

enum ServiceUnit {
  sqft
  sqm
  sqcm
  inch
  ft
  yd
  mm
  cm
  m
  meter
  pack
  piece
  roll
  box
  ream
  bottle
  liter
  hour
  PER_PAGE
  PER_100
  PER_SQ_METER
  PER_SET
  PER_YARD
}

model PriceList {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  displayName String // Customer-facing name
  salePrice   Float // Retail price

  // Contextual Categories pulled from the Price List's role
  materialCategory MaterialCategory?
  serviceCategory  ServiceCategory?

  // The Recipe: Multiple services/price items can point to one Material
  materialId String?
  material   Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Job Links
  jobs         Job[]
  jobVariables JobVariable[]

  @@index([orgId, isActive])
  @@index([materialId])
  @@index([serviceId])
  @@index([materialCategory])
  @@index([serviceCategory])
}

enum MaterialCalculationType {
  FLAT // Quantity only (e.g., 100 Business Card Blanks)
  DIMENSIONAL // Width x Height x Quantity (e.g., Vinyl, Flex, Acrylic)
  LINEAR // Length x Quantity (e.g., Binding coils, Framing timber)
  VOLUMETRIC // Liters/Grams (e.g., Ink, Resin)
}

enum MaterialCategory {
  MEDIA // Vinyl, Paper, Canvas, Fabric
  RIGID // Foam board, Alucobond, Acrylic, Wood
  CONSUMABLE // Ink, Toner, Glue, Laminate
  FINISHING // Eyelets, Roll-up stands, Frames, Binding wires
  HARDWARE // Spare parts, Blades
}

enum MaterialStatus {
  ACTIVE
  ARCHIVED // Discontinued by supplier
  OUT_OF_STOCK // Temporarily unavailable
}

model Material {
  id            String                  @id @default(cuid())
  name          String // Internal/Technical name
  calcType      MaterialCalculationType
  unit          ServiceUnit
  purchasePrice Float // Base cost per unit

  // 1-to-1 link to physical stock
  stockItemId String?    @unique
  stockItem   StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)

  priceListItems PriceList[]
  jobVariables   JobVariable[]

  @@index([name])
}

enum ServiceCalculationType {
  FIXED // A one-time fee regardless of size (e.g., Design Fee, Setup Fee)
  PER_UNIT // Charged per item (e.g., Eyelet punching, Lamination per sheet)
  AREA_BASED // Labor depends on size (e.g., Installation labor per sqft, Weeding vinyl)
  TIME_BASED // Charged per duration (e.g., Machine hourly rate, Consulting)
}

enum ServiceCategory {
  DESIGN // Graphic design, Pre-press, Layout
  PRINTING // Actual machine time (Digital, Offset, Large Format)
  FINISHING // Cutting, Folding, Laminating, Eyeleting
  INSTALLATION // Site visits, Mounting, Vehicle wrapping
  LOGISTICS // Delivery, Packaging, Handling
}

model Service {
  id        String                 @id @default(cuid())
  name      String // Workshop/Operation name
  calcType  ServiceCalculationType
  basePrice Float // Standard rate for the effort

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  priceListItems PriceList[]
  jobVariables   JobVariable[]
}

//
// ─────────────────────────────────────────────
// 6. STOCK
// ─────────────────────────────────────────────
//

model StockItem {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  // Current Physical State
  totalRemaining    Float @default(0)
  lowStockThreshold Float @default(0)

  // Link back to Material Definition
  material       Material?
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([totalRemaining]) // Fast filtering for out-of-stock
}

model StockMovement {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  type     StockMovementType
  quantity Float // Amount added/removed

  // Context: Why did this move?
  referenceId   String? // JobID or JobVariableID
  referenceType String? // "JOB" or "JOB_VARIABLE"

  note      String?
  createdBy String // User ID
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([stockItemId, createdAt(sort: Desc)]) // Fast history lookup
  @@index([referenceId])
}

enum StockMovementType {
  RESTOCK
  DEDUCT
  WASTE
  ADJUST
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  QUALITY_CHECK
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
  PAUSED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model Job {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // --- Core Reference ---
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id])

  // We keep serviceName as a snapshot of PriceList.displayName 
  // so the invoice doesn't change if you rename the PriceList item later.
  serviceName String

  // --- Multi-Service Support ---
  variables JobVariable[]

  // --- Dimensions & Quantity ---
  quantity Float
  width    Float?
  height   Float?
  unit     ServiceUnit? // Pulled from the linked Material

  // --- Financial Snapshots (Critical for Production) ---
  basePrice     Float // Snapshot of PriceList.salePrice at time of order
  variableTotal Float @default(0)
  totalPrice    Float // (basePrice * quantity/area) + variableTotal

  costPrice    Float? // Sum of Material.purchasePrice * usage
  profitMargin Float? // totalPrice - costPrice

  // --- Payment & Status ---
  paymentStatus PaymentStatus @default(UNPAID)
  isPaid        Boolean       @default(false)
  status        JobStatus     @default(PENDING)

  // --- Relations ---
  assignedStaffId String?
  assignedStaff   Staff?  @relation("StaffJobs", fields: [assignedStaffId], references: [id])

  deliveries   Delivery[]
  payments     Payment[]
  b2bPushId    String?
  b2bPush      B2BPush?   @relation("B2BPushResult", fields: [b2bPushId], references: [id])
  b2bSourceFor B2BPush[]  @relation("B2BOriginalSource")

  // --- Meta ---
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId, status])
  @@index([orgId, paymentStatus])
  @@index([clientId])
  @@index([priceListId])
  @@index([createdAt(sort: Desc)])
}

model JobVariable {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Direct mapping to the PriceList item added as a variable
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id])

  // Calculation Snapshot
  quantity  Float
  unitPrice Float // Price at time of creation
  subtotal  Float

  createdAt  DateTime  @default(now())
  material   Material? @relation(fields: [materialId], references: [id])
  materialId String?
  service    Service?  @relation(fields: [serviceId], references: [id])
  serviceId  String?

  @@index([jobId])
  @@index([priceListId])
}

//
// ─────────────────────────────────────────────
// 8. DELIVERY
// ─────────────────────────────────────────────
//
enum DeliveryType {
  PHYSICAL_PICKUP
  PRINTER_DELIVERY
  CLIENT_COURIER
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  PAUSED
  FAILED
}

model Delivery {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  // ─────────────────────────────────────────────
  // RELATIONS (domain integrity)
  // ─────────────────────────────────────────────
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // ─────────────────────────────────────────────
  // DELIVERY CORE
  // ─────────────────────────────────────────────
  type   DeliveryType
  status DeliveryStatus @default(PENDING)

  scheduledDate DateTime?
  deliveredAt   DateTime?

  handledBy String?
  address   String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─────────────────────────────────────────────
  // INDEXES (dispatch + logistics performance)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, jobId])
  @@index([orgId, clientId])
  @@index([scheduledDate])
  @@index([status])
}

//
// ─────────────────────────────────────────────
// 9. PAYMENTS
// ─────────────────────────────────────────────
//

enum PaymentMethod {
  CASH
  MOMO
  BANK_TRANSFER
  CARD
  OTHER
}

model Payment {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  // ─────────────────────────────────────────────
  // RELATION (financial integrity)
  // ─────────────────────────────────────────────
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  // ─────────────────────────────────────────────
  // PAYMENT CORE
  // ─────────────────────────────────────────────
  amount    Float
  method    PaymentMethod
  reference String?

  screenshotUrl String?

  confirmedBy String?
  confirmedAt DateTime @default(now())

  createdAt DateTime @default(now())

  // ─────────────────────────────────────────────
  // INDEXES (finance + reporting performance)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, jobId])
  @@index([orgId, method])
  @@index([orgId, confirmedAt])
  @@index([reference])
}

//
// ─────────────────────────────────────────────
// 10. B2B LAYER
// ─────────────────────────────────────────────
//
enum B2BStatus {
  PENDING
  ACCEPTED
  NEGOTIATING
  REJECTED
  COMPLETED
}

model B2BPush {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  // ─────────────────────────────────────────────
  // RELATION (critical fix)
  // ─────────────────────────────────────────────
  originalJobId String
  originalJob   Job    @relation("B2BOriginalSource", fields: [originalJobId], references: [id])

  jobs Job[] @relation("B2BPushResult")

  // ─────────────────────────────────────────────
  // BUSINESS SNAPSHOT DATA
  // ─────────────────────────────────────────────
  clientName  String
  serviceName String
  specs       String
  deadline    DateTime

  suggestedPrice Float?

  // ─────────────────────────────────────────────
  // WORKFLOW STATE
  // ─────────────────────────────────────────────
  status B2BStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─────────────────────────────────────────────
  // INDEXES (workflow + urgency optimization)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, originalJobId])
  @@index([deadline])
}

//
model AuditLog {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  // ─────────────────────────────────────────────
  // EVENT DATA
  // ─────────────────────────────────────────────
  action     String
  entityId   String
  entityType String

  performedBy String

  meta Json?

  timestamp DateTime @default(now())

  // ─────────────────────────────────────────────
  // INDEXES (debug + analytics + compliance)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, entityType])
  @@index([orgId, entityId])
  @@index([timestamp(sort: Desc)])
}
