generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma" // Required in v7
}

// organisationId
datasource db {
  provider = "postgresql"
  // Note: No 'url' here anymore
}

//
// ─────────────────────────────────────────────
// 1. ORGANISATION (MULTI-TENANT ROOT)
// ─────────────────────────────────────────────
//

model Organisation {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logoUrl      String?
  contactEmail String?
  contactPhone String?
  address      String?
  createdAt    DateTime @default(now())

  // Relations (Using the updated PriceList name)
  outboxEvents   OutboxEvent[]
  users          User[]
  staff          Staff[]
  clients        Client[]
  jobs           Job[]
  stockItems     StockItem[]
  stockMovements StockMovement[]
  prices         PriceList[]
  deliveries     Delivery[]
  b2bPushes      B2BPush[]
  auditLogs      AuditLog[]

  // Performance Indexes
  @@index([name])
  @@index([createdAt])
}

//
// ─────────────────────────────────────────────
// 2. AUTH / USERS / RBAC
// ─────────────────────────────────────────────
//

model OutboxEvent {
  id      String @id @default(cuid())
  type    String
  payload Json
  orgId   String

  // Add this to link it properly
  organisation Organisation @relation(fields: [orgId], references: [id])

  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  // Add this index for performance
  @@index([orgId])
  @@index([status])
}

enum UserRole {
  ADMIN
  OPERATOR
  CASHIER
  GUEST
  GRAPHIC_DESIGNER
}

model User {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  name      String
  email     String   @unique // @unique already creates a high-performance index
  role      UserRole
  avatarUrl String?
  createdAt DateTime @default(now())

  staffProfile Staff?

  // INDEXING:
  @@index([orgId]) // Critical: Ensures users stay within their organization
  @@index([role]) // Fast lookup for global or org-level permission checks
  @@index([createdAt]) // Useful for sorting the newest sign-ups
}

//
// ─────────────────────────────────────────────
// 3. STAFF
// ─────────────────────────────────────────────
//

model Staff {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  name           String
  role           UserRole
  phone          String?
  avatarUrl      String?
  specialisation String?
  isActive       Boolean  @default(true)

  assignedJobs Job[] @relation("StaffJobs")

  createdAt DateTime @default(now())

  // INDEXING:
  @@index([orgId]) // Standard for multi-tenant isolation
  @@index([name]) // Fast lookup for team lists and dropdowns
  @@index([isActive]) // Important for filtering out former employees
  @@index([role]) // Useful for permission checks and role-based filtering
  @@index([orgId, isActive]) // Compound index for loading the active team list
}

//
// ─────────────────────────────────────────────
// 4. CLIENTS
// ─────────────────────────────────────────────
//

enum ClientType {
  PRIVATE
  COMPANY
}

model Client {
  id    String @id @default(cuid())
  orgId String

  type        ClientType
  name        String
  companyName String?
  email       String?
  phone       String
  location    String?

  profilePictureUrl String?

  isNew         Boolean @default(true)
  recentStaffId String?

  lastJobId            String?
  lastJobDate          DateTime?
  totalJobs            Int       @default(0)
  mostPrintedServiceId String?

  notes     String?
  jobs      Job[]
  createdAt DateTime @default(now())

  organisation Organisation @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([orgId, phone])
  @@index([orgId, name])
  @@index([orgId, lastJobDate])
  @@index([orgId, totalJobs])
  @@index([recentStaffId])
  @@index([mostPrintedServiceId])
  @@index([lastJobId])
}

//
// ─────────────────────────────────────────────
// 5. PRICE LIST
// ─────────────────────────────────────────────
//

enum ServiceUnit {
  sqft
  sqm
  sqcm
  inch
  ft
  yd
  mm
  cm
  m
  meter
  pack
  piece
  roll
  box
  ream
  bottle
  liter
  hour
  PER_PAGE
  PER_100
  PER_SQ_METER
  PER_SET
  PER_YARD
}

model PriceList {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  name      String
  category  String
  unit      ServiceUnit
  costPrice Float?
  priceGHS  Float

  // 🔥 FORMAL RELATION: Connects PriceList to the StockItem table
  // This ensures the "Joinery" is visible in Prisma Studio and enforced by DB
  stockRefId String?
  stockItem  StockItem? @relation(fields: [stockRefId], references: [id])

  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  // INDEXING:
  @@index([orgId])
  @@index([category])
  @@index([isActive])
  @@index([stockRefId])
  @@index([orgId, isActive])
}

//
// ─────────────────────────────────────────────
// 6. STOCK
// ─────────────────────────────────────────────
//

model StockItem {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  name              String
  unit              String
  totalRemaining    Float
  lowStockThreshold Float
  lastUnitCost      Float
  lastRestockedAt   DateTime?

  createdAt      DateTime        @default(now())
  stockMovements StockMovement[]

  // 🔥 THE FIX: Add the opposite relation field
  // This allows one StockItem to be linked to multiple PriceList entries
  prices PriceList[]

  // INDEXING:
  @@index([orgId])
  @@index([name])
  @@index([totalRemaining])
  @@index([lastRestockedAt])
}

model RestockRecord {
  id          String   @id @default(cuid())
  stockItemId String
  quantity    Float
  unitCost    Float
  totalCost   Float
  recordedBy  String
  date        DateTime @default(now())

  // INDEXING:
  @@index([stockItemId]) // Critical for viewing the restock history of a specific item
  @@index([date(sort: Desc)]) // Optimized for "Recent Restocks" logs (newest first)
  @@index([recordedBy]) // Useful for auditing who logged which inventory update
}

model StockMovement {
  id String @id @default(cuid())

  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  type StockMovementType

  quantity Float
  unitCost Float?

  // useful for traceability (job, restock, waste, adjustment)
  referenceId   String?
  referenceType String? // "JOB" | "RESTOCK" | "WASTE" | "MANUAL"

  note String?

  createdBy String
  createdAt DateTime @default(now())

  // INDEXING
  @@index([orgId])
  @@index([stockItemId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@index([referenceId])
}

enum StockMovementType {
  RESTOCK
  DEDUCT
  WASTE
  ADJUST
}

//
// ─────────────────────────────────────────────
// 7. JOB ENGINE
// ─────────────────────────────────────────────
//

enum JobStatus {
  PENDING
  IN_PROGRESS
  QUALITY_CHECK
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
  PAUSED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model Job {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  serviceId   String
  serviceName String

  quantity Float
  width    Float?
  height   Float?
  unit     String?

  totalPrice   Float
  costPrice    Float?
  profitMargin Float?

  materialUsed    Float?
  materialWastage Float?

  status        JobStatus     @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  isPaid        Boolean       @default(false)

  paymentRef String?

  assignedStaffId String?
  assignedStaff   Staff?  @relation("StaffJobs", fields: [assignedStaffId], references: [id])

  deliveryId String?

  notes String?

  b2bPushId String?
  b2bPush   B2BPush? @relation(fields: [b2bPushId], references: [id])

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  completedAt DateTime?
  deliveries  Delivery[]

  // INDEXING:
  @@index([orgId]) // Standard isolation
  @@index([clientId]) // Fast lookup for "all jobs for this customer"
  @@index([status]) // Critical for "Production Board" views (Pending vs Printing)
  @@index([paymentStatus]) // Essential for "Unpaid Jobs" financial reports
  @@index([assignedStaffId]) // Useful for "My Tasks" view for staff members
  @@index([createdAt(sort: Desc)]) // Optimized for the main Dashboard (newest first)
  @@index([orgId, status]) // Compound index for lightning-fast Kanban boards
  @@index([b2bPushId])
}

//
// ─────────────────────────────────────────────
// 8. DELIVERY
// ─────────────────────────────────────────────
//

enum DeliveryType {
  PHYSICAL_PICKUP
  PRINTER_DELIVERY
  CLIENT_COURIER
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  PAUSED
  FAILED
}

model Delivery {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  clientId String // Should likely have a relation to the Client model too

  type   DeliveryType
  status DeliveryStatus @default(PENDING)

  scheduledDate DateTime?
  deliveredAt   DateTime?

  handledBy String?
  address   String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // INDEXING:
  @@index([orgId]) // Standard multi-tenant isolation
  @@index([jobId]) // Fast lookup for a specific Job's delivery status
  @@index([status]) // Critical for "Pending" vs "Delivered" dispatch views
  @@index([scheduledDate]) // Optimized for the "Deliveries for Today" calendar view
  @@index([clientId]) // Useful for viewing a specific client's delivery history
}

//
// ─────────────────────────────────────────────
// 9. PAYMENTS
// ─────────────────────────────────────────────
//

enum PaymentMethod {
  CASH
  MOMO
  BANK_TRANSFER
  CARD
  OTHER
}

model Payment {
  id    String @id @default(cuid())
  orgId String
  jobId String

  amount    Float
  method    PaymentMethod
  reference String?

  screenshotUrl String?

  confirmedBy String?
  confirmedAt DateTime @default(now())

  // INDEXING:
  @@index([orgId]) // Essential for multi-tenant data isolation
  @@index([jobId]) // Fast lookup for all payments related to a specific Job
  @@index([method]) // Useful for financial reporting (e.g., total Mobile Money vs Cash)
  @@index([confirmedAt]) // Optimized for date-range reports (e.g., "Payments this week")
  @@index([reference]) // Allows instant lookup when searching for a transaction ID/Ref
}

//
// ─────────────────────────────────────────────
// 10. B2B LAYER
// ─────────────────────────────────────────────
//

enum B2BStatus {
  PENDING
  ACCEPTED
  NEGOTIATING
  REJECTED
  COMPLETED
}

model B2BPush {
  id    String @id @default(cuid())
  orgId String

  originalJobId String

  clientName  String
  serviceName String
  specs       String
  deadline    DateTime

  suggestedPrice Float?

  status B2BStatus @default(PENDING)
  jobs   Job[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organisation   Organisation? @relation(fields: [organisationId], references: [id])
  organisationId String?

  // INDEXING:
  @@index([orgId]) // Essential for multi-tenant filtering
  @@index([status]) // Fast lookup for "Pending" or "Completed" pushes
  @@index([originalJobId]) // Critical for linking back to the source Job
  @@index([deadline]) // Useful for sorting by urgency
}

//
// ─────────────────────────────────────────────
// 11. AUDIT LOG
// ─────────────────────────────────────────────
//

model AuditLog {
  id    String @id @default(cuid())
  orgId String

  action     String
  entityId   String
  entityType String

  performedBy String

  meta Json?

  timestamp      DateTime      @default(now())
  organisation   Organisation? @relation(fields: [organisationId], references: [id])
  organisationId String?

  // INDEXING:
  @@index([orgId]) // Fast filtering by Organisation
  @@index([entityId, entityType]) // Fast lookup for a specific item's history (e.g., all logs for Job X)
  @@index([timestamp(sort: Desc)]) // Optimized for "Recent Activity" feeds
}
