{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],

    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/zodiac/*"],
      "@root/*": ["./app/*"],

      "@api/*": ["app/api/*"],

      "@components/*": ["app/zodiac/components/*"],
      "@core/*": ["app/zodiac/core/*"],
      "@screens/*": ["app/zodiac/screens/*"],
      "@store/*": ["app/zodiac/store/*"],
      "@ui/*": ["app/zodiac/ui/*"],
      "@view/*": ["app/zodiac/view/*"],
      "@types/*": ["app/zodiac/types/*"],
      "@process/*": ["app/zodiac/process/*"],
      "@schema/*": ["app/zodiac/schema/*"],

      "@lib/*": ["app/lib/*"],
      "@hooks/*": ["app/lib/hooks/*"],

      "@services/*": ["app/lib/services/*"],

      "@prisma/*": ["prisma/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
