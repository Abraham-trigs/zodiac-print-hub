{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [{ "name": "next" }],

    "baseUrl": ".",
    "paths": {
      "@/*": ["app/*"],
      "@api/*": ["app/api/*"],

      "@components/*": ["app/components/*"],
      "@common/*": ["app/components/common/*"],
      "@core/*": ["app/components/core/*"],
      "@screens/*": ["app/components/screens/*"],
      "@modals/*": ["app/components/modals/*"],
      "@workstation/*": ["app/components/workstation/*"],
      "@web/*": ["app/components/web/*"],

      "@store/*": ["app/store/*"],
      "@store-core/*": ["app/store/core/*"],
      "@store-slices/*": ["app/store/slices/*"],
      "@store-selectors/*": ["app/store/selectors/*"],

      "@zodiac/*": ["app/zodiac/*"],
      "@view/*": ["app/zodiac/view/*"],

      "@lib/*": ["app/lib/*"],
      "@client/*": ["app/lib/client/*"],
      "@hooks/*": ["app/lib/client/hooks/*"],
      "@server/*": ["app/lib/server/*"],

      "@services/*": ["app/lib/server/services/*"],
      "@repositories/*": ["app/lib/server/repositories/*"],
      "@queue/*": ["app/lib/server/queue/*"],
      "@events/*": ["app/lib/server/events/*"],

      "@generated/*": ["./generated*"],

      "@shared/*": ["app/lib/shared/*"],
      "@schema/*": ["app/lib/shared/schema/*"],
      "@types/*": ["app/lib/shared/types/*"],
      "@utils/*": ["app/lib/shared/utils/*"],

      "@prisma/*": ["prisma/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
