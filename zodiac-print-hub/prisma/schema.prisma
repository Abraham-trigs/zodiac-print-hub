generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma" // Required in v7
}

// organisationId
datasource db {
  provider = "postgresql"
  // Note: No 'url' here anymore
}

//
// ─────────────────────────────────────────────
// 1. ORGANISATION (MULTI-TENANT ROOT)
// ─────────────────────────────────────────────
//

model Organisation {
  id       String  @id @default(cuid())
  name     String
  slug     String  @unique
  isActive Boolean @default(true) // 1. Added for SaaS management

  logoUrl      String?
  contactEmail String?
  contactPhone String?
  address      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // 2. Added for audit/syncing

  // Core Relations
  users   User[]
  staff   Staff[]
  clients Client[]
  jobs    Job[]
  prices  PriceList[]

  // Resources & Inventory (Aligned with our Brainstorm)
  materials Material[] // 3. Added Material link
  services  Service[] // 4. Added Service link

  stockItems     StockItem[]
  stockMovements StockMovement[]
  deliveries     Delivery[]
  b2bPushes      B2BPush[]
  auditLogs      AuditLog[]
  outboxEvents   OutboxEvent[]
  payments       Payment[]

  @@index([name])
  @@index([slug])
  @@index([createdAt])
  @@index([isActive]) // 5. Index for fast SaaS status checks
}

//
// ─────────────────────────────────────────────
// 2. AUTH / USERS / RBAC
// ─────────────────────────────────────────────
//

model OutboxEvent {
  id      String @id @default(cuid())
  type    String
  payload Json
  orgId   String

  organisation Organisation @relation(fields: [orgId], references: [id])

  status OutboxStatus @default(PENDING)

  attempts    Int       @default(0)
  lastError   String?
  processedAt DateTime?

  // 🚀 The "Smart Worker" Field
  // If an email fails (e.g., SMTP down), the worker sets this to 
  // +5 mins so it doesn't keep spamming the failing service.
  nextAttemptAt DateTime? @default(now())

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([status, nextAttemptAt]) // Updated: Worker only picks up events where nextAttemptAt <= Now
}

enum OutboxStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// Enum for user roles across system
enum UserRole {
  ADMIN
  STAFF
  CUSTOMER
}

model User {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  email     String
  name      String
  avatarUrl String?
  role      UserRole

  // --- Passwordless Auth Fields ---
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  // This is used for Magic Link / OTP verification
  // Usually short-lived and cleared after use
  authThreshold DateTime?

  staffProfile Staff?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, email])
  @@index([email])
  @@index([orgId, isActive])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String // Typically the email
  token      String   @unique
  expires    DateTime
  orgId      String

  @@unique([identifier, token])
  @@index([expires]) // For cleanup workers
}

//
// ─────────────────────────────────────────────
// 3. STAFF
// ─────────────────────────────────────────────
//

model Staff {
  id    String @id @default(cuid())
  orgId String

  // Relation to identity
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Professional-only fields
  phone          String?
  specialisation String? // e.g., "Large Format", "Finishing", "Design"
  isActive       Boolean @default(true)

  // 🚀 Production Addition: Efficiency Tracking
  // Useful for reporting who finishes jobs fastest or handles the most volume
  joinedAt   DateTime?
  baseSalary Float? // Optional: for internal payroll tracking

  organisation Organisation @relation(fields: [orgId], references: [id])
  assignedJobs Job[]        @relation("StaffJobs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([orgId, isActive])
  @@index([specialisation]) // Index for fast filtering when assigning jobs
}

//
// ─────────────────────────────────────────────
// 4. CLIENTS
// ─────────────────────────────────────────────
//

enum ClientType {
  PRIVATE
  COMPANY
}

model Client {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  type        ClientType
  name        String
  companyName String?
  email       String?
  phone       String
  location    String?

  profilePictureUrl String?

  // ─────────────────────────────────────────────
  // Lightweight CRM state (cached projections)
  // ─────────────────────────────────────────────
  isNew         Boolean @default(true)
  recentStaffId String?

  lastJobId   String?
  lastJobDate DateTime?

  totalJobs Int @default(0)

  mostPrintedServiceId String?

  notes String?

  // ─────────────────────────────────────────────
  // Relations
  // ─────────────────────────────────────────────
  jobs Job[]

  createdAt  DateTime   @default(now())
  deliveries Delivery[]

  // ─────────────────────────────────────────────
  // INDEXING (SaaS + CRM performance layer)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, phone])
  @@index([orgId, name])
  @@index([orgId, lastJobDate])
  @@index([orgId, totalJobs])
  @@index([orgId, isNew])
  @@index([recentStaffId])
  @@index([mostPrintedServiceId])
  @@index([lastJobId])
}

//
// ─────────────────────────────────────────────
// 5. PRICE LIST
// ─────────────────────────────────────────────
//

enum PriceItemType {
  MATERIAL
  SERVICE
}

enum ServiceUnit {
  sqft
  sqm
  sqcm
  inch
  ft
  yd
  mm
  cm
  m
  meter
  pack
  piece
  roll
  box
  ream
  bottle
  liter
  hour
  PER_PAGE
  PER_100
  PER_SQ_METER
  PER_SET
  PER_YARD
}

model PriceList {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  displayName String // Customer-facing name
  salePrice   Float // Retail price

  // Contextual Categories pulled from the Price List's role
  materialCategory MaterialCategory?
  serviceCategory  ServiceCategory?

  // The Recipe: Multiple services/price items can point to one Material
  materialId String?
  material   Material? @relation(fields: [materialId], references: [id], onDelete: SetNull)

  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Job Links
  jobs         Job[]
  jobVariables JobVariable[]

  @@index([orgId, isActive])
  @@index([materialId])
  @@index([serviceId])
  @@index([materialCategory])
  @@index([serviceCategory])
}

enum MaterialCalculationType {
  FLAT // Quantity only (e.g., 100 Business Card Blanks)
  DIMENSIONAL // Width x Height x Quantity (e.g., Vinyl, Flex, Acrylic)
  LINEAR // Length x Quantity (e.g., Binding coils, Framing timber)
  VOLUMETRIC // Liters/Grams (e.g., Ink, Resin)
}

enum MaterialCategory {
  MEDIA // Vinyl, Paper, Canvas, Fabric
  RIGID // Foam board, Alucobond, Acrylic, Wood
  CONSUMABLE // Ink, Toner, Glue, Laminate
  FINISHING // Eyelets, Roll-up stands, Frames, Binding wires
  HARDWARE // Spare parts, Blades
}

enum MaterialStatus {
  ACTIVE
  ARCHIVED // Discontinued by supplier
  OUT_OF_STOCK // Temporarily unavailable
}

model Material {
  id            String                  @id @default(cuid())
  name          String 
  calcType      MaterialCalculationType
  unit          ServiceUnit
  purchasePrice Float 

  // 📏 Physical Geometry (Existing V2)
  rollWidth     Float?                  @default(0) 

  // 🚚 PROCUREMENT LINKS (Phase 1)
  // Ties this material to its primary source
  supplierId    String?
  supplier      Supplier?               @relation(fields: [supplierId], references: [id], onDelete: SetNull)
   
  // 🚚 LOGISTICS SPECS (Phase 4)
  leadTimeDays   Int?      @default(3)      // Days from Order to Arrival
  minOrderQty    Int?      @default(1)      // Smallest purchase unit
  buyQuantity    Float?    @default(1)      // Units per pack (e.g., 150ft per roll)
  buyUnit        String?   @default("roll") // "roll", "box", "pack"
  // 📦 PROCUREMENT SPECS (Phase 2 & 3)
  buyUnit       String?                 @default("roll") // "roll", "box", "pack"
  buyQuantity   Float?                  @default(1)      // e.g., 150 (if a roll is 150ft)
  minOrderQty   Int?                    @default(1)
  
  // 🛰️ RELATIONS
  stockItemId   String?                 @unique
  stockItem     StockItem?              @relation(fields: [stockItemId], references: [id], onDelete: SetNull)

  priceListItems PriceList[]
  jobVariables   JobVariable[]
  printLayouts   MaterialPrintLayout[]
  purchaseItems  StockPurchaseItem[]    // History of purchases for this material

  orgId          String
  organisation   Organisation           @relation(fields: [orgId], references: [id])

  @@unique([orgId, name])
  @@index([name])
  @@index([supplierId])
}


enum ServiceCalculationType {
  FIXED // A one-time fee regardless of size (e.g., Design Fee, Setup Fee)
  PER_UNIT // Charged per item (e.g., Eyelet punching, Lamination per sheet)
  AREA_BASED // Labor depends on size (e.g., Installation labor per sqft, Weeding vinyl)
  TIME_BASED // Charged per duration (e.g., Machine hourly rate, Consulting)
}

enum ServiceCategory {
  DESIGN // Graphic design, Pre-press, Layout
  PRINTING // Actual machine time (Digital, Offset, Large Format)
  FINISHING // Cutting, Folding, Laminating, Eyeleting
  INSTALLATION // Site visits, Mounting, Vehicle wrapping
  LOGISTICS // Delivery, Packaging, Handling
}

model Service {
  id        String                 @id @default(cuid())
  name      String // Workshop/Operation name
  calcType  ServiceCalculationType
  basePrice Float // Standard rate for the effort

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  priceListItems PriceList[]
  jobVariables   JobVariable[]
  orgId          String
  organisation   Organisation  @relation(fields: [orgId], references: [id])

  @@unique([orgId, name])
}

//
// ─────────────────────────────────────────────
// 6. STOCK
// ─────────────────────────────────────────────
//

model StockItem {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  // Current Physical State
  totalRemaining    Float @default(0)
  lowStockThreshold Float @default(0)

  // Link back to Material Definition
  material       Material?
  stockMovements StockMovement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([totalRemaining]) // Fast filtering for out-of-stock
}

model StockMovement {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  type     StockMovementType
  quantity Float // Amount added/removed

  // Context: Why did this move?
  referenceId   String? // JobID or JobVariableID
  referenceType String? // "JOB" or "JOB_VARIABLE"

  note      String?
  createdBy String // User ID
  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([stockItemId, createdAt(sort: Desc)]) // Fast history lookup
  @@index([referenceId])
}

enum StockMovementType {
  RESTOCK
  DEDUCT
  WASTE
  ADJUST
}

model Supplier {
  id            String    @id @default(cuid())
  orgId         String
  name          String
  email         String?
  phone         String?
  address       String?
  
  // 🏷️ Categorization (This is where you specify "Stock" vs "Service")
  category      String?   // e.g., "SUBSTRATES", "HARDWARE", "UTILITIES"
  
  // 🏢 B2B BRIDGE
  linkedUserId  String?   @unique 
  
  // 🛰️ RELATIONS
  materials      Material[]
  purchaseOrders StockPurchaseOrder[]

  organisation  Organisation @relation(fields: [orgId], references: [id])
  createdAt     DateTime     @default(now())

  @@index([orgId])
  @@unique([orgId, name]) // A shop can't have two suppliers with the same name
}
model StockPurchaseOrder {
  id              String        @id @default(cuid())
  orgId           String
  
  supplierId      String
  supplier        Supplier      @relation(fields: [supplierId], references: [id])

  status          POStatus      @default(DRAFT)
  
  // 🔗 LINK: The specific Job that triggered this (Phase 2)
  relatedJobId    String?
  
  totalCost       Float         @default(0)
  items           StockPurchaseItem[]

  // 🚚 LOGISTICS
  expectedArrival DateTime?
  receivedAt      DateTime?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orgId])
  @@index([status])
}

model StockPurchaseItem {
  id               String             @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    StockPurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  materialId       String
  material         Material           @relation(fields: [materialId], references: [id])

  quantity         Float              // How many you are buying (e.g., 10)
  buyUnit          String             // e.g., "Roll"
  unitPrice        Float              // Snapshot of price per Roll
}

enum POStatus {
  DRAFT
  ORDERED     // Sent to Supplier (Stock is "In-Transit")
  RECEIVED    // Physical Goods arrived (StockMovement Triggered)
  CANCELLED
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  QUALITY_CHECK
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
  PAUSED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model Job {
  id           String       @id @default(cuid())
  orgId        String
  organisation Organisation @relation(fields: [orgId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // 🏷️ PRODUCTION IDENTIFIER (V2 Addition)
  // The 4-character code (e.g., "7x2a") written inside layout boxes.
  shortRef     String?      @unique

  // 🔗 LAYOUT ENGINE LINK (V2 Addition)
  // Connects this job to its specific position on a MaterialPrintLayout.
  layoutItem   PrintLayoutItem?

    // 🎨 PROOFING & APPROVAL
  proofUrl      String?     // URL to the uploaded design/proof
  proofStatus   ProofStatus @default(PENDING)
  customerNote  String?     // Feedback from the customer
  approvalToken String?     @unique @default(cuid()) // Secure link token
  approvedAt    DateTime?

  enum ProofStatus {
  PENDING       // No proof uploaded yet
  AWAITING      // Staff uploaded, waiting for customer
  REVISION      // Customer requested changes
  APPROVED      // Customer said yes
}

  // --- Core Reference ---
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id])

  serviceName String

  // --- Multi-Service Support ---
  variables JobVariable[]

  // --- Dimensions & Quantity ---
  quantity Float
  width    Float?
  height   Float?
  unit     ServiceUnit? 

  // --- Financial Snapshots ---
  basePrice     Float 
  variableTotal Float @default(0)
  totalPrice    Float 

  costPrice    Float? 
  profitMargin Float? 

  // --- Payment & Status ---
  paymentStatus PaymentStatus @default(UNPAID)
  isPaid        Boolean       @default(false)
  status        JobStatus     @default(PENDING)

  // --- Relations ---
  assignedStaffId String?
  assignedStaff   Staff?  @relation("StaffJobs", fields: [assignedStaffId], references: [id])

  deliveries   Delivery[]
  payments     Payment[]
  b2bPushId    String?
  b2bPush      B2BPush?   @relation("B2BPushResult", fields: [b2bPushId], references: [id])
  b2bSourceFor B2BPush[]  @relation("B2BOriginalSource")

  // --- Meta ---
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orgId, status])
  @@index([orgId, paymentStatus])
  @@index([clientId])
  @@index([priceListId])
  @@index([shortRef]) // 🚀 Added for fast lookup in the PrintLayoutBuilder
  @@index([createdAt(sort: Desc)])
}


model JobVariable {
  id    String @id @default(cuid())
  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // 🏷️ VISUAL IDENTIFIER (V2 Sync)
  // We use a sub-ref so the printer knows this is an add-on (e.g., "7x2a-V1")
  shortRef     String?      @unique 

  // 🔗 LAYOUT ENGINE LINK
  // Allows the "Lamination" or "Backing" to be nested on its own material run
  layoutItem   PrintLayoutItem?

  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id])

  // --- Dimensions for Variables ---
  quantity Float
  width    Float?
  height   Float?

  unitPrice Float
  subtotal  Float

  material   Material? @relation(fields: [materialId], references: [id])
  materialId String?
  service    Service?  @relation(fields: [serviceId], references: [id])
  serviceId  String?

  orgId     String
  createdAt DateTime @default(now())

  @@index([orgId, jobId])
  @@index([jobId])
  @@index([shortRef])
  @@index([priceListId])
}


// --- NEW: THE MAP (MaterialPrintLayout) ---
model MaterialPrintLayout {
  id              String         @id @default(cuid())
  orgId           String
  materialId      String
  material        Material       @relation(fields: [materialId], references: [id])
  
  rollWidth       Float          // Snapshot of roll width
  cutLineHeight   Float          // Where the straight cut happens
  efficiency      Float          // Area Used / Total Canvas Area
  totalWastedArea Float          // Shaded "Big Margin" area
  
  items           PrintLayoutItem[]
  status          LayoutStatus   @default(DRAFT)
  createdAt       DateTime       @default(now())

  @@index([orgId])
}

// --- NEW: THE BOXES (PrintLayoutItem) ---
model PrintLayoutItem {
  id            String               @id @default(cuid())
  layoutId      String
  layout        MaterialPrintLayout  @relation(fields: [layoutId], references: [id], onDelete: Cascade)
  
  jobId         String               @unique
  job           Job                  @relation(fields: [jobId], references: [id])

  posX          Float
  posY          Float
  isRotated     Boolean              @default(false)
  width         Float
  height        Float
}

enum LayoutStatus { DRAFT; LOCKED; COMPLETED; CANCELLED }


// watse
// ─────────────────────────────────────────────
// 8. DELIVERY
// ─────────────────────────────────────────────
//
enum DeliveryType {
  PHYSICAL_PICKUP
  PRINTER_DELIVERY
  CLIENT_COURIER
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  OUT_FOR_DELIVERY
  DELIVERED
  PAUSED
  FAILED
}

model Delivery {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  // ─────────────────────────────────────────────
  // RELATIONS (domain integrity)
  // ─────────────────────────────────────────────
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // ─────────────────────────────────────────────
  // DELIVERY CORE
  // ─────────────────────────────────────────────
  type   DeliveryType
  status DeliveryStatus @default(PENDING)

  scheduledDate DateTime?
  deliveredAt   DateTime?

  handledBy String?
  address   String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─────────────────────────────────────────────
  // INDEXES (dispatch + logistics performance)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, jobId])
  @@index([orgId, clientId])
  @@index([scheduledDate])
  @@index([status])
}

//
// ─────────────────────────────────────────────
// 9. PAYMENTS
// ─────────────────────────────────────────────
//

enum PaymentMethod {
  CASH
  MOMO
  BANK_TRANSFER
  CARD
  OTHER
}

model Payment {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  // ─────────────────────────────────────────────
  // RELATION (financial integrity)
  // ─────────────────────────────────────────────
  jobId String
  job   Job    @relation(fields: [jobId], references: [id])

  // ─────────────────────────────────────────────
  // PAYMENT CORE
  // ─────────────────────────────────────────────
  amount    Float
  method    PaymentMethod
  reference String?

  screenshotUrl String?

  confirmedBy String?
  confirmedAt DateTime @default(now())

  createdAt DateTime @default(now())

  // ─────────────────────────────────────────────
  // INDEXES (finance + reporting performance)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, jobId])
  @@index([orgId, method])
  @@index([orgId, confirmedAt])
  @@index([reference])
}

//
// ─────────────────────────────────────────────
// 10. B2B LAYER
// ─────────────────────────────────────────────
//
enum B2BStatus {
  PENDING
  ACCEPTED
  NEGOTIATING
  REJECTED
  COMPLETED
}

model B2BPush {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  // ─────────────────────────────────────────────
  // RELATION (critical fix)
  // ─────────────────────────────────────────────
  originalJobId String
  originalJob   Job    @relation("B2BOriginalSource", fields: [originalJobId], references: [id])

  jobs Job[] @relation("B2BPushResult")

  // ─────────────────────────────────────────────
  // BUSINESS SNAPSHOT DATA
  // ─────────────────────────────────────────────
  clientName  String
  serviceName String
  specs       String
  deadline    DateTime

  suggestedPrice Float?

  // ─────────────────────────────────────────────
  // WORKFLOW STATE
  // ─────────────────────────────────────────────
  status B2BStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─────────────────────────────────────────────
  // INDEXES (workflow + urgency optimization)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, status])
  @@index([orgId, originalJobId])
  @@index([deadline])
}

model AuditLog {
  id    String @id @default(cuid())
  orgId String

  organisation Organisation @relation(fields: [orgId], references: [id])

  // ─────────────────────────────────────────────
  // EVENT DATA
  // ─────────────────────────────────────────────
  action     String
  entityId   String
  entityType String

  performedBy String

  meta Json?

  timestamp DateTime @default(now())

  // ─────────────────────────────────────────────
  // INDEXES (debug + analytics + compliance)
  // ─────────────────────────────────────────────
  @@index([orgId])
  @@index([orgId, entityType])
  @@index([orgId, entityId])
  @@index([timestamp(sort: Desc)])
}
